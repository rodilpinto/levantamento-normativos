# ===========================================================================
# Levantamento de Normativos -- Project .gitignore
# ===========================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/

# ---------------------------------------------------------------------------
# Streamlit secrets (never commit real API keys)
# ---------------------------------------------------------------------------
.streamlit/secrets.toml

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# OS-generated files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Test outputs (Excel files generated during testing at project root)
# ---------------------------------------------------------------------------
/*.xlsx

# ---------------------------------------------------------------------------
# pytest cache
# ---------------------------------------------------------------------------
.pytest_cache/

# ---------------------------------------------------------------------------
# Claude Code session data
# ---------------------------------------------------------------------------
.claude/
